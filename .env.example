# ──────────────────────────────────────────────
#  Psybot — Environment Variables
#  Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Discord bot token (required)
TOKEN=your-bot-token-here

# Prefix for text commands (default: ,)
PREFIX=,

# ── Channel IDs ────────────────────────────────

# Channel where "Join to Create" temporary VCs are spawned
JOIN_TO_CREATE_CHANNEL_ID=1505260263924961330

# Channel where the Reaction Roles panel is posted
REACTION_ROLES_CHANNEL_ID=1510256263743934504

# Channel where the Ticket panel button is posted
TICKET_PANEL_CHANNEL_ID=1505164021186433075

# Channel to send welcome messages when a member joins
WELCOME_CHANNEL_ID=1445406874231898153

# ── Role IDs ───────────────────────────────────

# Role ID that grants admin access to bot commands (close, rrpanel, ticket, send, purge)
ADMIN_ROLE_ID=your-admin-role-id-here
