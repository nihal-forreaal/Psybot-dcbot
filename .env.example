TOKEN=your-bot-token-here
PREFIX=!

# Discord channel / role / category IDs
DISCORD_ANNOUNCE_CHANNEL_ID=your-announcement-channel-id
ADMIN_ROLE_ID=your-admin-role-id
TICKET_CATEGORY_ID=your-ticket-category-id
TICKET_PANEL_CHANNEL_ID=your-ticket-panel-channel-id
VC_CATEGORY_ID=your-voice-category-id
CREATE_VC_CHANNEL_ID=your-create-vc-channel-id
LEVEL_CHANNEL_ID=your-level-channel-id

# Level reward roles are created/found by name automatically:
# 1=Nobby, 2=Normie, 5=Rookie, 10=Grinder, 15=Sweaty,
# 20=Pro, 30=Elite, 35=Legend, 40=Mythic, 50=Godmode.
# Optional comma-separated role IDs if you want to use existing roles by ID.
# Format: level:roleId,level:roleId
LEVEL_ROLE_IDS=1:role-id,2:role-id,5:role-id,10:role-id,15:role-id,20:role-id,30:role-id,35:role-id,40:role-id,50:role-id

# YouTube live notifications
YT_CHANNEL_ID=your-youtube-channel-id
YT_PORT=3000
PUBLIC_URL=https://your-public-url.example
YT_CALLBACK_PATH=/youtube/callback
YT_VERIFY_TOKEN=change-this-token
